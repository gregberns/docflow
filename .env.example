# Anthropic API key for document classification and extraction.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# PostgreSQL connection (jdbc URL points at the docker-compose postgres service).
DB_URL=jdbc:postgresql://postgres:5432/docflow
DB_USER=docflow
DB_PASSWORD=docflow

# Filesystem root for stored document bytes inside the backend container.
STORAGE_ROOT=/var/lib/docflow/storage

# Host-side port mappings. The backend always listens on 8080 inside its
# container; BACKEND_HOST_PORT controls what host port that is published on.
# Defaults are applied in docker-compose.yml if these are unset.
BACKEND_HOST_PORT=8551
FRONTEND_HOST_PORT=5173
